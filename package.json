{
  "name": "legalify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run build:css:watch\" \"next dev\"",
    "build": "npm run build:css && next build",
    "start": "next start",
    "lint": "eslint",
    "build:css": "npx @tailwindcss/cli -i src/app/tailwind.css -o src/app/globals.css",
    "build:css:watch": "npx @tailwindcss/cli -i src/app/tailwind.css -o src/app/globals.css --watch",
    "verify:ui": "node scripts/verify-ui.mjs",
    "verify:ui:all": "node scripts/verify-ui.mjs all"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@supabase/supabase-js": "^2.104.0",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "framer-motion": "^12.38.0",
    "html2pdf.js": "^0.14.0",
    "jimp": "^1.6.1",
    "lucide-react": "^1.11.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "openai": "^6.35.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.5.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
